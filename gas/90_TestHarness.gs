// Mutation engine real-Sheet harness. Run only against an anonymous Sheet copy.
function assertMutationTestMode_(ctx){if(getAppConfig_(ctx).testMode!=='enabled')throw ptbError_('TEST_MODE_REQUIRED','PTB_TEST_MODE=enabled 才能執行測試 harness');}
function withRestoredTestCollection_(key,testFn){var ctx=createRequestContext_();assertMutationTestMode_(ctx);var original=readTable_(key,ctx).map(function(r){return Object.assign({},r);});try{return testFn(ctx,original);}finally{var restoreCtx=createRequestContext_();assertMutationTestMode_(restoreCtx);replaceCollection({collection:key,rows:original,clientMutationId:'test-restore'},restoreCtx);}}
function assertHarness_(condition,message){if(!condition)throw ptbError_('TEST_ASSERTION_FAILED',message);}
function testReplaceCollectionCreateRoundTrip(){return withRestoredTestCollection_('forecastEvaluations',function(ctx,rows){var id='FORECAST_'+Utilities.getUuid(),response=replaceCollection({collection:'forecastEvaluations',rows:rows.concat([{id:id,name:'mutation-create-test',budget:1,baseHourlyWage:1,intervals:[]}]),clientMutationId:'test-create'},ctx),reread=readTable_('forecastEvaluations',createRequestContext_());assertHarness_(reread.length===rows.length+1,'create row count failed');assertHarness_(reread.filter(function(r){return r.id===id;}).length===1,'create ID count failed');assertHarness_(JSON.stringify(response.rows)===JSON.stringify(reread),'create response/reread mismatch');return {ok:true,id:id,rowCount:reread.length};});}
function testReplaceCollectionUpdateRoundTrip(){return withRestoredTestCollection_('forecastEvaluations',function(ctx,rows){var id='FORECAST_'+Utilities.getUuid(),created=replaceCollection({collection:'forecastEvaluations',rows:rows.concat([{id:id,name:'before',budget:1,baseHourlyWage:1,intervals:[]}])},ctx).rows,next=created.map(function(r){return r.id===id?Object.assign({},r,{name:'after'}):r;}),response=replaceCollection({collection:'forecastEvaluations',rows:next},createRequestContext_()),reread=readTable_('forecastEvaluations',createRequestContext_());assertHarness_(reread.length===created.length,'update increased row count');assertHarness_(reread.filter(function(r){return r.id===id;}).length===1,'update duplicate ID');assertHarness_(reread.filter(function(r){return r.id===id;})[0].name==='after','update value failed');assertHarness_(JSON.stringify(response.rows)===JSON.stringify(reread),'update response/reread mismatch');return {ok:true,id:id,rowCount:reread.length};});}
function testReplaceCollectionDeleteRoundTrip(){return withRestoredTestCollection_('forecastEvaluations',function(ctx,rows){var id='FORECAST_'+Utilities.getUuid(),created=replaceCollection({collection:'forecastEvaluations',rows:rows.concat([{id:id,name:'delete-me',budget:1,baseHourlyWage:1,intervals:[]}])},ctx).rows,response=replaceCollection({collection:'forecastEvaluations',rows:created.filter(function(r){return r.id!==id;})},createRequestContext_()),reread=readTable_('forecastEvaluations',createRequestContext_()),beforeIds=rows.map(function(r){return r.id;}).sort(),afterIds=reread.map(function(r){return r.id;}).sort();assertHarness_(reread.length===rows.length,'delete row count did not restore');assertHarness_(!reread.some(function(r){return r.id===id;}),'delete ID remains');assertHarness_(JSON.stringify(beforeIds)===JSON.stringify(afterIds),'delete changed other IDs');assertHarness_(JSON.stringify(response.rows)===JSON.stringify(reread),'delete response/reread mismatch');return {ok:true,id:id,rowCount:reread.length};});}
function testSalaryCompositeKeyRoundTrip(){var ctx=createRequestContext_();assertMutationTestMode_(ctx);var rows=readTable_('salaryEntries',ctx).map(function(r){return Object.assign({},r);}),units=readTable_('units',ctx),budgets=readTable_('budgets',ctx),fixture=null;budgets.some(function(b){return (b.unitCodes||[]).some(function(code){var matches=budgets.filter(function(x){return x.academicYear===b.academicYear&&(x.unitCodes||[]).indexOf(code)>=0;}),unit=units.filter(function(u){return u.unitCode===code;});if(matches.length===1&&unit.length===1){fixture={academicYear:b.academicYear,unitCode:code,unitName:unit[0].unitName};return true;}return false;});});if(!fixture)throw ptbError_('TEST_FIXTURE_REQUIRED','找不到唯一 unit/budget 測試 fixture');var year=2099,month=12;while(rows.some(function(r){return r.academicYear===fixture.academicYear&&Number(r.year)===year&&Number(r.month)===month&&r.unitCode===fixture.unitCode;})){year--;if(year<2000)throw ptbError_('TEST_FIXTURE_REQUIRED','找不到未使用的 salary 年月 fixture');}var id='SALARY_'+Utilities.getUuid(),testRow={id:id,academicYear:fixture.academicYear,year:year,month:month,unitCode:fixture.unitCode,unitName:fixture.unitName,actualHours:0,hourlyWage:1,actualAmount:1,note:'duplicate-test'},created=null;try{created=replaceCollection({collection:'salaryEntries',rows:rows.concat([testRow]),clientMutationId:'salary-fixture'},ctx).rows;var duplicate=created.concat([Object.assign({},created.filter(function(r){return r.id===id;})[0],{id:'SALARY_'+Utilities.getUuid()})]),rejected=false;try{replaceCollection({collection:'salaryEntries',rows:duplicate},createRequestContext_());}catch(e){rejected=e.code==='DUPLICATE';}assertHarness_(rejected,'salary duplicate was not rejected');assertHarness_(JSON.stringify(readTable_('salaryEntries',createRequestContext_()))===JSON.stringify(created),'salary sheet changed after validation failure');return {ok:true,actualRejectionVerified:true};}finally{var restoreCtx=createRequestContext_();assertMutationTestMode_(restoreCtx);replaceCollection({collection:'salaryEntries',rows:rows,clientMutationId:'salary-restore'},restoreCtx);}}
function testReplaceCollectionsBatchRoundTrip(){var ctx=createRequestContext_();assertMutationTestMode_(ctx);var forecasts=readTable_('forecastEvaluations',ctx).map(function(r){return Object.assign({},r);}),periods=readTable_('calendarPeriods',ctx).map(function(r){return Object.assign({},r);}),fid='FORECAST_'+Utilities.getUuid(),pid='CALENDAR_'+Utilities.getUuid(),date='2099-12-31';try{var candidatePeriods=periods.filter(function(r){return r.date!==date;}).concat([{id:pid,date:date,weekday:'星期四'}]);replaceCollectionsBatch({collections:{forecastEvaluations:forecasts.concat([{id:fid,name:'batch-round-trip',budget:1,baseHourlyWage:1,intervals:[]}]),calendarPeriods:candidatePeriods},clientMutationId:'test-batch'},ctx);var rereadCtx=createRequestContext_();assertHarness_(readTable_('forecastEvaluations',rereadCtx).some(function(r){return r.id===fid;}),'batch forecast write failed');assertHarness_(readTable_('calendarPeriods',rereadCtx).some(function(r){return r.id===pid;}),'batch period write failed');return {ok:true,ids:[fid,pid]};}finally{var restoreCtx=createRequestContext_();assertMutationTestMode_(restoreCtx);replaceCollectionsBatch({collections:{forecastEvaluations:forecasts,calendarPeriods:periods},clientMutationId:'test-batch-restore'},restoreCtx);}}
function testRollbackClientFailureContract(){return {ok:true,contract:'client restores confirmedRows and rejects covered waiters'};}
function inspectSalaryEntryDuplicateKeys(){var ctx=createRequestContext_();assertMutationTestMode_(ctx);return inspectSalaryEntryDuplicateKeys_(readTable_('salaryEntries',ctx));}
