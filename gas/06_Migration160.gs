function inspectPtb160Schema(){var c=getAppConfig_(),report={spreadsheetConfigured:!!c.spreadsheetId,tables:[],blockers:[],warnings:[]};if(!c.spreadsheetId){report.blockers.push('尚未設定 PTB_SPREADSHEET_ID');return report;}var ss=getSpreadsheet_();Object.keys(PTB_TABLES).forEach(function(k){var d=PTB_TABLES[k],s=ss.getSheetByName(d.sheet),headers=s&&s.getLastColumn()?s.getRange(1,1,1,s.getLastColumn()).getDisplayValues()[0].map(String):[],missing=d.headers.filter(function(h){return headers.indexOf(h)<0;}),extra=headers.filter(function(h){return d.headers.indexOf(h)<0;});report.tables.push({table:d.sheet,exists:!!s,currentHeaders:headers,missingHeaders:missing,extraHeaders:extra,rowCount:s?Math.max(0,s.getLastRow()-1):0,blockers:missing.slice(),warnings:extra.length?['保留未知欄位']:[]});if(k==='budgets'&&s&&s.getLastRow()>1&&(missing.indexOf('budgetName')>=0||missing.indexOf('unitCodes')>=0))report.warnings.push('legacy 01_budgets 群組欄位將保持空白，不自動虛構 mapping');});return report;}
function migratePtb160Schema(){return withWriteLock_(function(){var ss=getSpreadsheet_(),changes=[];Object.keys(PTB_TABLES).forEach(function(k){var d=PTB_TABLES[k],s=ss.getSheetByName(d.sheet);if(!s){s=ss.insertSheet(d.sheet);s.getRange(1,1,1,d.headers.length).setValues([d.headers]);changes.push({table:d.sheet,created:true,appendedHeaders:d.headers});return;}var headers=s.getLastColumn()?s.getRange(1,1,1,s.getLastColumn()).getDisplayValues()[0].map(String):[],missing=d.headers.filter(function(h){return headers.indexOf(h)<0;});if(missing.length){s.getRange(1,headers.length+1,1,missing.length).setValues([missing]);changes.push({table:d.sheet,created:false,appendedHeaders:missing});}var finalHeaders=headers.concat(missing);finalHeaders.forEach(function(h,i){if(/^(id|academicYear|unitCode|year|month|date|startTime|endTime|sourceHourSettingId)$/.test(h))s.getRange(1,i+1,s.getMaxRows(),1).setNumberFormat('@');});});return {ok:true,changes:changes,inspection:inspectPtb160Schema()};});}
function verifyPtb160Schema(){var r=inspectPtb160Schema(),fail=r.blockers.length>0||r.tables.some(function(t){return !t.exists||t.missingHeaders.length>0;});return {ok:!fail,status:fail?'FAIL':'PASS',inspection:r};}
