function getWorkStudyBootstrapData(){var c=getAppConfig_(),data={};Object.keys(PTB_TABLES).forEach(function(k){data[k]=k==='scheduleTypes'?readOptionalTable_(k):readTable_(k);});return {ok:true,appVersion:c.appVersion,writeMode:c.writeMode,data:data};}
function saveRecord_(key,input){return withWriteLock_(function(){var id=cleanString_(input&&input.id),existing=id?findRowById_(key,id):null,valid=validateRecord_(key,input||{},existing&&existing.record),now=nowIso_();if(existing)return updateRecordById_(key,id,valid);return appendRecord_(key,Object.assign({},valid,{id:createId_(key),createdAt:now,updatedAt:now}));});}
function deleteRecords_(key,ids){return withWriteLock_(function(){return deleteRowsByIds_(key,ids);});}
