function saveCalendarPeriod(p){return saveRecord_('calendarPeriods',p);} function deleteCalendarPeriods(p){return withWriteLock_(function(){var start=cleanString_(p.startDate),end=cleanString_(p.endDate);if(!/^\d{4}-\d{2}-\d{2}$/.test(start)||!/^\d{4}-\d{2}-\d{2}$/.test(end)||start>end)throw ptbError_('VALIDATION_ERROR','日期範圍錯誤');var periodResult=deleteRowsByIds_('calendarPeriods',p.ids),rowIds=readTable_('calendarRows').filter(function(r){return r.date>=start&&r.date<=end;}).map(function(r){return r.id;}),rowResult=deleteRowsByIds_('calendarRows',rowIds);periodResult.deletedCalendarRowIds=rowResult.deletedIds;return periodResult;});}
